{
  // Versionary config version
  "$schema": "https://raw.githubusercontent.com/jolars/versionary/main/schemas/versionary-schema.json",
  "version": 1,
  "mode": "simple",
  "releaseFlow": {
    "mode": "review"
  },
  "bootstrap-sha": "f46f767",

  "simple": {
    "versionFile": "version.txt",
    "changelogFile": "CHANGELOG.md",
    "releaseBranchPrefix": "versionary/release",
    "baselineShaFile": ".versionary-manifest.json"
  }
}
