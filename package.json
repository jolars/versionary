{
  "name": "versionary",
  "version": "0.1.0",
  "description": "Automatic release framework based on conventional commits and semantic versioning",
  "keywords": [
    "releasing",
    "semantic versioning",
    "conventional commits"
  ],
  "homepage": "https://github.com/jolars/versionary#readme",
  "bugs": {
    "url": "https://github.com/jolars/versionary/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jolars/versionary.git"
  },
  "license": "MIT",
  "author": "Johan Larsson",
  "type": "commonjs",
  "packageManager": "pnpm@10.33.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "verify": "tsx src/cli/index.ts verify"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
