{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jolars/versionary/main/schemas/config.json",
  "title": "Versionary configuration",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "const": 1
    },
    "review-mode": {
      "type": "string",
      "enum": ["direct", "review"]
    },
    "version-file": {
      "type": "string"
    },
    "changelog-file": {
      "type": "string"
    },
    "release-branch": {
      "type": "string"
    },
    "baseline-file": {
      "type": "string"
    },
    "bootstrap-sha": {
      "type": "string"
    },
    "monorepo-mode": {
      "type": "string",
      "enum": ["independent", "fixed"]
    },
    "bump-minor-pre-major": {
      "type": "boolean"
    },
    "allow-stable-major": {
      "type": "boolean"
    },
    "include-commit-authors": {
      "type": "boolean"
    },
    "release-type": {
      "type": "string"
    },
    "packages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "release-type": {
            "type": "string"
          },
          "package-name": {
            "type": "string"
          },
          "exclude-paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extra-files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": ["json", "toml", "yaml", "regex"]
                },
                "path": {
                  "type": "string"
                },
                "jsonpath": {
                  "type": "string"
                },
                "pattern": {
                  "type": "string"
                }
              },
              "required": ["type", "path"],
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
