{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/jolars/versionary/main/schemas/config.json",
  "title": "Versionary configuration",
  "type": "object",
  "required": ["version"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "const": 1
    },
    "review-mode": {
      "type": "string",
      "enum": ["direct", "review"]
    },
    "version-file": {
      "type": "string"
    },
    "changelog-file": {
      "type": "string"
    },
    "release-branch": {
      "type": "string"
    },
    "baseline-file": {
      "type": "string"
    },
    "bootstrap-sha": {
      "type": "string"
    },
    "monorepo-mode": {
      "type": "string",
      "enum": ["independent", "fixed"]
    },
    "bump-minor-pre-major": {
      "type": "boolean"
    },
    "allow-stable-major": {
      "type": "boolean"
    },
    "include-commit-authors": {
      "type": "boolean"
    },
    "release-type": {
      "type": "string"
    },
    "packages": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "release-type": {
            "type": "string"
          },
          "package-name": {
            "type": "string"
          },
          "exclude-paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "extra-files": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["json", "toml", "yaml"]
                    },
                    "path": {
                      "type": "string"
                    },
                    "jsonpath": {
                      "type": "string"
                    }
                  },
                  "required": ["type", "path", "jsonpath"],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "regex"
                    },
                    "path": {
                      "type": "string"
                    },
                    "pattern": {
                      "type": "string"
                    }
                  },
                  "required": ["type", "path", "pattern"],
                  "additionalProperties": false
                }
              ]
            }
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
